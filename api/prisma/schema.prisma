// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== TEAMS / WORKSPACES ====================
enum TeamRole {
  OWNER
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     TeamMember[]
  invitations TeamInvitation[]
  tasks       Task[]
  events      Event[]
  categories  Category[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamInvitation {
  id        String           @id @default(cuid())
  teamId    String
  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email     String
  code      String           @unique
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())

  @@map("team_invitations")
}

// ==================== USERS ====================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  categories         Category[]
  tasks              Task[]             @relation("TaskOwner")
  assignedTasks      Task[]             @relation("TaskAssignee")
  events             Event[]            @relation("EventOwner")
  assignedEvents     Event[]            @relation("EventAssignee")
  teamMembers        TeamMember[]
  attachmentsPending Attachment[]       @relation("UserPendingAttachments")
  pushSubscriptions  PushSubscription[]
  activityLogs       ActivityLog[]

  @@map("users")
}

// ==================== PUSH SUBSCRIPTIONS ====================
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ==================== CATEGORIES ====================
// Domyślne: "Dom", "Firma" - ale użytkownik może tworzyć własne
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3B82F6") // Tailwind blue-500
  icon      String?
  isDefault Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks  Task[]
  events Event[]

  @@unique([userId, name, teamId])
  @@index([userId, teamId])
  @@map("categories")
}

// ==================== TASKS ====================
// Zadania - mogą być "niezaplanowane" (w Inbox) lub "zaplanowane" (na kalendarzu)
model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  // Scheduling - null oznacza "w Inbox", wypełnione = "zaplanowane"
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  scheduledAllDay Boolean   @default(false) // true = tylko dzień, bez konkretnej godziny

  // Deadline (opcjonalny - "do kiedy" niezależnie od scheduledStart)
  deadline DateTime?

  // Priority: 1 = low, 2 = medium, 3 = high, 4 = urgent
  priority Int @default(2)

  // Recurrence (format RRULE z iCalendar)
  recurrenceRule String?

  // Attachment (zdjęcie)
  imageUrl String?

  // Reminder (null = brak powiadomienia)
  reminderMinutes Int?
  reminderSent    Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId      String
  user        User         @relation("TaskOwner", fields: [userId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  teamId      String?
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  activityLogs ActivityLog[]

  @@index([userId, isCompleted])
  @@index([userId, scheduledStart])
  @@index([userId, deadline])
  @@index([reminderSent, scheduledStart])
  @@index([reminderSent, deadline])
  @@index([userId, teamId])
  @@index([assigneeId])
  @@index([teamId, assigneeId])
  @@map("tasks")
}

// ==================== ACTIVITY LOGS ====================
// Historia zmian zadań - używana głównie w workspace'ach zespołowych,
// ale rejestrowana także dla zadań prywatnych (na wypadek przyszłych
// potrzeb audytu). Każdy wpis jest niezależny i tylko do odczytu.
model ActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([userId])
  @@map("activity_logs")
}

// ==================== EVENTS ====================
// Wydarzenia - zawsze mają sztywny czas (start + end)
model Event {
  id          String  @id @default(cuid())
  title       String
  description String?
  location    String?

  // Czas - wydarzenia ZAWSZE mają czas
  startTime DateTime
  endTime   DateTime
  isAllDay  Boolean  @default(false)

  // Recurrence (format RRULE z iCalendar)
  recurrenceRule String?

  // Reminder (null = brak powiadomienia)
  reminderMinutes Int?
  reminderSent    Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId      String
  user        User         @relation("EventOwner", fields: [userId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("EventAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  teamId      String?
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([userId, startTime])
  @@index([reminderSent, startTime])
  @@index([userId, teamId])
  @@index([assigneeId])
  @@index([teamId, assigneeId])
  @@map("events")
}

// ==================== ATTACHMENTS ====================
// Pliki przypisane do zadania lub wydarzenia (lokalnie w uploads/).
//
// Po zmianie schematu uruchom w katalogu api:
//   npx prisma db push
// albo (zalecane na produkcji):
//   npx prisma migrate dev --name add_attachments
model Attachment {
  id           String @id @default(cuid())
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String

  taskId  String?
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Oczekujące (przed utworzeniem zadania/wydarzenia) — usuwane po expiresAt (np. 15 min)
  userId    String?
  user      User?     @relation("UserPendingAttachments", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([eventId])
  @@index([userId])
  @@index([expiresAt])
  @@map("attachments")
}
