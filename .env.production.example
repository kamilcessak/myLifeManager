# ===========================================
# Production Environment Variables
# Copy this file to .env.production and fill in real values
# ===========================================

# Domain (without https://) — leave empty to serve on IP via HTTP
# When you have a domain, set all three:
DOMAIN=
FRONTEND_URL=http://localhost
API_URL=http://localhost
# With domain it would be:
# DOMAIN=myapp.example.com
# FRONTEND_URL=https://myapp.example.com
# API_URL=https://myapp.example.com

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=mylifemanager

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Upload
MAX_FILE_SIZE=5242880

# Web Push — generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_KEY=
PRIVATE_VAPID_KEY=
VAPID_EMAIL=mailto:your-email@example.com
