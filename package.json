{
  "name": "my-life-manager",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "web",
      "shared",
      "mobile"
    ],
    "nohoist": [
      "mobile/**"
    ]
  },
  "scripts": {
    "api:dev": "yarn workspace api dev",
    "api:build": "yarn workspace api build",
    "web:dev": "yarn workspace web dev",
    "web:build": "yarn workspace web build",
    "db:migrate": "yarn workspace api prisma migrate dev",
    "db:generate": "yarn workspace api prisma generate",
    "db:studio": "yarn workspace api prisma studio",
    "mobile:start": "yarn workspace mobile start",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d",
    "prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
    "prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "prod:backup": "bash deploy/backup.sh"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.0"
  }
}
